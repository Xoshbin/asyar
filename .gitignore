# OS / editor
.DS_Store
.idea/
*.swp
*.swo

# Workspace dependencies
node_modules/

# Local-only Claude config — never tracked, anywhere in the tree
.claude/

# Dogfood extensions live in their own repos; setup.mjs clones them here
/extensions/

# Build artifacts (subpackages have their own .gitignore too — this is belt + suspenders)
dist/
build/
.svelte-kit/
target/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.*.local
.vscode/Asyar-Project.code-workspace
