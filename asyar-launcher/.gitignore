src-tauri/resources/
# Sidecar binaries (bun, uv, claude, …) are large and fetched per-platform by
# scripts/download-sidecars.mjs at build time — never commit them. Ignore the
# whole dir except its tracked metadata so any future sidecar can't be either
# accidentally committed or, once added to tauri.conf.json externalBin, silently
# left unprovisioned (external-bin-provisioning.test.mjs guards that second case).
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep
!src-tauri/binaries/README.md
.roo/
.roomodes
.agents/
logs.txt
*.tgz
.idea/
.claude/
